<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document <%= status === 'approved' ? 'Approved' : 'Rejected' %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      margin: 0;
      padding: 0;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      /* background-color: <%= status === 'approved' ? '#28a745' : '#dc3545' %>; */
      color: white;
      padding: 20px;
      text-align: center;
    }
    .content {
      padding: 20px;
      background-color: #f9f9f9;
    }
    .footer {
      font-size: 12px;
      color: #777;
      text-align: center;
      margin-top: 20px;
    }
    .details {
      background-color: #fff;
      border: 1px solid #ddd;
      padding: 15px;
      margin: 15px 0;
      border-radius: 5px;
    }
    .button {
      display: inline-block;
      background-color: #4A90E2;
      color: white;
      text-decoration: none;
      padding: 10px 20px;
      border-radius: 5px;
      margin-top: 15px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Document <%= status === 'approved' ? 'Approved' : 'Rejected' %></h1>
    </div>
    <div class="content">
      <p>Hello <%= name %>,</p>
      
      <% if (status === 'approved') { %>
        <p>We're pleased to inform you that your <%= documentType.replace('_', ' ') %> has been <strong>approved</strong>.</p>
        
        <% if (employeeId) { %>
        <div class="details">
          <p><strong>Your Employee ID:</strong> <%= employeeId %></p>
        </div>
        <% } %>
        
        <p>You can now proceed with accepting service requests on the platform.</p>
      <% } else { %>
        <p>We regret to inform you that your <%= documentType.replace('_', ' ') %> has been <strong>rejected</strong>.</p>
        
        <% if (remarks) { %>
        <div class="details">
          <p><strong>Reason:</strong> <%= remarks %></p>
        </div>
        <% } %>
        
        <p>Please upload a new document addressing the issues mentioned above.</p>
      <% } %>
      
      <a href="shayakpartner://documents" class="button">View Documents</a>
      
      <p>If you have any questions or need assistance, please contact our support team.</p>
    </div>
    <div class="footer">
      <p>&copy; <%= new Date().getFullYear() %> Shayak Partner. All rights reserved.</p>
      <p>This is an automated message, please do not reply directly to this email.</p>
    </div>
  </div>
</body>
</html>